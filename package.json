{
  "name": "health-tracer",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "corepack pnpm --dir packages/db db:migrate",
    "db:seed": "corepack pnpm --dir packages/db db:seed:exercises && corepack pnpm --dir packages/db db:seed:recipes && corepack pnpm --dir packages/db db:seed:habit-templates",
    "db:seed:recipes": "corepack pnpm --dir packages/db db:seed:recipes",
    "db:seed:exercises": "corepack pnpm --dir packages/db db:seed:exercises",
    "db:seed:nutrition-demo": "corepack pnpm --dir packages/db db:seed:nutrition-demo",
    "db:seed:demo-nutrition-week-plan": "corepack pnpm --dir packages/db db:seed:demo-nutrition-week-plan"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
