    "@nestjs/core": "^11.1.25",
    "@nestjs/platform-express": "^11.1.25",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.9",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stripe": "^22.2.0",
    "zod": "^4.4.3"
