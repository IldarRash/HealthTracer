{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "postgres-dev": {
      "command": "postgres-mcp",
      "args": ["--readonly"],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}"
      }
    }
  }
}
