PORT=3000
API_PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/health_tracer
CLERK_JWKS_URL=https://example.clerk.accounts.dev/.well-known/jwks.json
LAB_REPORT_STORAGE_PATH=.data/lab-reports
CHAT_ATTACHMENT_STORAGE_PATH=.data/chat-attachments
AI_COACH_PROVIDER=stub
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Override model for the lab-report biomarker extraction stage (falls back to OPENAI_MODEL)
# OPENAI_MODEL_LAB_EXTRACTION=gpt-4o-mini
# CORS_ORIGINS is REQUIRED in production (comma-separated allowed browser origins).
# The API fails closed (no CORS) when this is unset in production.
# Example: CORS_ORIGINS=https://health-web-production.up.railway.app
# CORS_ORIGINS=https://health-web-production.up.railway.app
# STORAGE_ALLOW_LOCAL_IN_PRODUCTION: local filesystem storage is dev-only by default.
# Set to "true" ONLY when a durable Railway volume is attached and you accept the
# ephemeral-storage limitation (uploads are lost on redeploy without a volume).
# STORAGE_ALLOW_LOCAL_IN_PRODUCTION=true
# Comma-separated browser origins for CORS (optional; defaults to reflect request Origin)
# CORS_ORIGINS=https://health-web-production-11ee.up.railway.app
# Recipe catalog provider: "themealdb" (default, hydrates from TheMealDB API on first browse/recommend) or "seeded_only"/"none"/"disabled" (use local seeded data only)
# RECIPE_CATALOG_PROVIDER=themealdb
