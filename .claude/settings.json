{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DO_NOT_TRACK": "1"
  },
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm lint)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm test)",
      "Bash(pnpm build)",
      "Bash(pnpm dev)",
      "Bash(corepack pnpm --dir *)",
      "Bash(pnpm --filter *)",
      "Bash(pnpm db:up)",
      "Bash(pnpm db:down)",
      "Bash(pnpm db:migrate)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(docker compose:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Bash(git push:*)",
      "Bash(rm -rf:*)",
      "Bash(drizzle-kit drop:*)"
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  }
}
