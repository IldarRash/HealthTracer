{
  "name": "@health/db",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed:recipes": "node ./scripts/seed-recipes.mjs",
    "db:seed:exercises": "node ./scripts/seed-exercises.mjs",
    "db:seed:habit-templates": "node ./scripts/seed-habit-templates.mjs",
    "db:seed:nutrition-demo": "node ./scripts/seed-nutrition-demo.mjs",
    "db:seed:demo-nutrition-week-plan": "node ./scripts/seed-demo-nutrition-week-plan.mjs",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "latest",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "drizzle-kit": "latest"
  }
}
