{
  "version": 1,
  "safetyFloors": {
    "requireMedicalConsent": true,
    "enforceProviderIsolation": true,
    "requireOwnershipChecks": true,
    "suppressMedicalPlanProposals": true
  },
  "categories": {
    "entries": [
      {
        "category": "unclassified",
        "allowedMimeTypes": [
          "image/jpeg",
          "image/png",
          "image/webp",
          "text/plain",
          "application/pdf"
        ],
        "maxBytes": 10000000,
        "label": "Unclassified upload"
      },
      {
        "category": "food_photo",
        "allowedMimeTypes": [
          "image/jpeg",
          "image/png",
          "image/webp"
        ],
        "maxBytes": 10000000,
        "label": "Food photo"
      },
      {
        "category": "medical_document",
        "allowedMimeTypes": [
          "text/plain",
          "application/pdf",
          "image/jpeg",
          "image/png",
          "image/webp"
        ],
        "maxBytes": 5000000,
        "label": "Medical document"
      },
      {
        "category": "workout_attachment",
        "allowedMimeTypes": [
          "image/jpeg",
          "image/png",
          "image/webp",
          "application/pdf",
          "text/plain"
        ],
        "maxBytes": 10000000,
        "label": "Workout attachment"
      }
    ],
    "provisionalUploadMimeTypes": [
      "image/jpeg",
      "image/png",
      "image/webp",
      "text/plain",
      "application/pdf"
    ],
    "maxProvisionalBytes": 10000000
  },
  "classification": {
    "llmClassifierPrompt": "You classify wellness coaching chat attachments.\nReturn JSON only. Do not answer the user or provide coaching advice.\nAllowed categories: food_photo, workout_attachment, medical_document.\nAllowed suggestedAction values: run_category_recognition, request_medical_consent, manual_fallback, unsupported.\nUse request_medical_consent for medical_document when explicit consent would be required before review.\nUse manual_fallback when the attachment is ambiguous, unrelated, or low confidence.\nNever default ambiguous images to food_photo. Prefer manual_fallback over guessing nutrition.\nAllowed JSON shape:\n{\"category\":\"food_photo|workout_attachment|medical_document\",\"confidence\":\"low|medium|high\",\"rationale\":\"short reason\",\"suggestedAction\":\"run_category_recognition|request_medical_consent|manual_fallback|unsupported\",\"mealContextLabel\":null|string}\nmealContextLabel is optional and only for food_photo when meal timing is evident from the message.",
    "llmUserPromptIntro": "Classify this chat attachment into exactly one allowed category.\nAllowed categories: food_photo, workout_attachment, medical_document.",
    "preferManualFallbackOverFoodGuess": true,
    "maxTextClassificationChars": 8000,
    "mealContextPatterns": [
